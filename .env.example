# Happy Talents backend — environment variables.
# Copy to `.env` and fill in. The `.env` file itself is git-ignored.

# --- Supabase (persistence) ---
# When both are set, transcripts are stored in Supabase. When empty, the backend
# falls back to an in-memory store (development only) so endpoints stay testable
# before the database is provisioned.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI analysis) ---
# API key for the transcript-analysis endpoint. Required for POST /api/v1/analyses.
OPENAI_API_KEY=
# Default model; can be overridden per prompt in the prompts/*.yaml files.
OPENAI_MODEL=gpt-4o-2024-08-06

# --- Plaud scraping (Selenium / Chromium) ---
# Paths to the Chromium binary and chromedriver. Leave empty on machines where
# Selenium Manager can resolve the driver automatically (typical local dev);
# set them explicitly in the Cloud Run / Docker image (e.g. /usr/bin/chromium).
CHROMIUM_PATH=
CHROMEDRIVER_PATH=

# Max seconds to wait for the Plaud share page to render before failing.
PLAUD_PAGE_TIMEOUT=20

# --- Google / Gmail ---
# Test phase: a single manually-generated OAuth2 refresh token (e.g. via the
# Google OAuth Playground) with scopes gmail.compose + gmail.settings.basic.
# Used by POST /api/v1/gmail/drafts and GET /api/v1/users/me/signature.
# Later this is replaced by per-user tokens from the SSO flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
